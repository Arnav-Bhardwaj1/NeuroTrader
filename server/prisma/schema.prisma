generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String
  passwordHash String
  cashBalance  Float         @default(25000.0)
  watchlists   Watchlist[]
  transactions Transaction[]
  holdings     Holding[]
}

model Watchlist {
  id      String @id @default(uuid())
  name    String
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  symbols String // e.g., JSON array string '["AAPL", "TSLA"]'
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  symbol    String
  action    String   // 'BUY' | 'SELL'
  shares    Int
  price     Float
  timestamp DateTime @default(now())
}

model Holding {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  symbol  String
  shares  Int
  avgCost Float

  @@unique([userId, symbol])
}
